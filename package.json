{
	"name": "@setup-automatizado/n8n-nodes-zedaapi",
	"version": "0.1.0",
	"description": "n8n community node for Zeda API — Complete WhatsApp integration powered by whatsmeow. 131 operations across 18 resources.",
	"license": "MIT",
	"homepage": "https://github.com/Setup-Automatizado/n8n-nodes-zedaapi",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"whatsapp",
		"zedaapi",
		"whatsmeow",
		"messaging",
		"automation",
		"chatbot",
		"whatsapp-api",
		"whatsapp-bot"
	],
	"author": {
		"name": "Setup Automatizado",
		"email": "contato@setupautomatizado.com.br",
		"url": "https://github.com/Setup-Automatizado"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Setup-Automatizado/n8n-nodes-zedaapi.git"
	},
	"bugs": {
		"url": "https://github.com/Setup-Automatizado/n8n-nodes-zedaapi/issues"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/ZedaApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/ZedaApi/ZedaApi.node.js",
			"dist/nodes/ZedaApi/ZedaApiTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
